{
  "name": "UserProfile",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "emoji_avatar": {
      "type": "string",
      "default": "\ud83d\ude0e"
    },
    "photo_avatar_url": {
      "type": "string"
    },
    "avatar_mode": {
      "type": "string",
      "enum": [
        "emoji",
        "photo",
        "flip"
      ],
      "default": "emoji"
    },
    "bio": {
      "type": "string"
    },
    "currency_label": {
      "type": "string",
      "default": "KSH"
    },
    "goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "theme": {
      "type": "string",
      "default": "lime"
    },
    "dark_mode": {
      "type": "boolean",
      "default": true
    },
    "vibe_score": {
      "type": "number",
      "default": 0
    },
    "total_owed": {
      "type": "number",
      "default": 0
    },
    "last_active_tab": {
      "type": "string",
      "default": "home"
    },
    "onboarding_complete": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "user_id",
    "display_name"
  ]
}